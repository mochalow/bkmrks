{
  "plugins": [
    "plugins/markdown"
  ],
  "source": {
    "include": [
      "../static/js/api.js",
      "../static/js/format.js",
      "../static/js/library.js",
      "../static/js/reader.js",
      "../static/js/theme.js"
    ]
  },
  "markdown": {
    "hardwrap": false,
    "idInHeadings": true
  },
  "opts": {
    "encoding": "utf8",
    "readme": "../README.md",
    "destination": "_build/js",
    "recurse": true,
    "title": "bkmrks"
  },

  "templates": {
    "default": {
      "layoutFile": "./layout.tmpl",
      "includeDate": false,
      "staticFiles": {
        "include": [
          "./jsdoc.css",
          "_static/favicon.svg"
        ]
      }
    }
  }
}